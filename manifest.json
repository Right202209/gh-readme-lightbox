{
  "manifest_version": 3,
  "name": "GitHub README 图片弹层预览",
  "version": "1.0.0",
  "description": "在 GitHub README 中点击图片时直接弹层预览，支持外链 banner、滚轮缩放和拖拽平移。",
  "permissions": [],
  "host_permissions": [
    "https://github.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "icons": {}
}